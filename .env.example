# Puerto donde correrá la aplicación
PORT=3010

# Base de Datos (PostgreSQL)
# En DigitalOcean App Platform, usa DATABASE_URL vinculada automáticamente.
DB_HOST=localhost
DB_PORT=5432
DB_USER=spa_user
DB_PASSWORD=spa_password
DB_NAME=spa_dev
DATABASE_URL=postgres://usuario:password@host:puerto/base_de_datos

# Seguridad
JWT_SECRET=tu_secreto_super_seguro_aqui_123
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Configuración de Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
